# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.coverage

# Django
/data/
staticfiles/
apps/base/static/base/img/brand-logo.png
apps/base/static/base/img/brand-favicon.gif
apps/ipso/static/ipso/pwa/img/brand-logo.gif

# IDE
