# Abies runtime configuration.
#
# In production, copy this file to /etc/abies/env, fill in real values, then:
#   chown root:root /etc/abies/env
#   chmod 0600      /etc/abies/env
# The systemd unit reads it via EnvironmentFile=.

# --- Django -----------------------------------------------------------------

# Random 50+-char string.  Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(64))'
DJANGO_SECRET_KEY=

DJANGO_DEBUG=0

# Comma-separated hostnames this app may be served as.
DJANGO_ALLOWED_HOSTS=laforesta.it

# Comma-separated origins (scheme://host) allowed to POST here.
DJANGO_CSRF_TRUSTED_ORIGINS=https://laforesta.it

# --- MS 365 OAuth -----------------------------------------------------------
# See CLAUDE.md > "MS 365 OAuth configuration" for tenant pinning rationale.

MS_OAUTH_CLIENT_ID=
MS_OAUTH_SECRET=
MS_OAUTH_TENANT=
