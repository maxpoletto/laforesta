#!/usr/bin/env bash
# bin/bootstrap-data <dev|prod>
#
# One-time data load for a FRESH (empty) abies instance on the VM. Delegates
# the in-app initialization sequence to bin/load-canonical-data.
#
# Canonical data location: the per-instance data dir
# /var/lib/abies-<instance>/data is bind-mounted to /app/data in the container
# (see compose/<instance>.yml), so sync canonical CSVs to
# /var/lib/abies-<instance>/data/canonical on the VM host; the container then
# reads them at /app/data/canonical.
#
# Use `make sync-canonical-<instance>` or the bootstrap Make targets to copy
# canonical data to the VM.
#
# `manage.py bootstrap` refuses a non-empty instance (it has no wipe), so run
# this only once, right after a fresh `bin/deploy <instance>` -- the container
# must be up. Running migrations here is intentional so a partially failed
# first deploy can still be recovered by staging data and rerunning this script.

set -euo pipefail

instance="${1:-}"
[[ "$instance" == "dev" || "$instance" == "prod" ]] || {
  echo "usage: $(basename "$0") <dev|prod>" >&2
  exit 1
}

context="${ABIES_DOCKER_CONTEXT:-vm-abies}"
ctr="abies-${instance}"

# In-container path under the bind-mounted data dir (/var/lib/abies-$instance/data).
canonical_dir=/app/data/canonical

# Container must be running for `docker exec` to attach.
state="$(docker --context "$context" inspect -f '{{.State.Running}}' "$ctr" 2>/dev/null || echo missing)"
[[ "$state" == "true" ]] || {
  echo "error: container '$ctr' not running on context '$context'." >&2
  echo "       run bin/deploy $instance first." >&2
  exit 1
}

x() { docker --context "$context" exec "$ctr" "$@"; }

# Fail early, with a clear message, if canonical data was not synced.
x test -d "$canonical_dir" || {
  echo "error: $canonical_dir not found in container '$ctr'." >&2
  echo "       sync canonical CSVs to /var/lib/abies-$instance/data/canonical on the VM host." >&2
  exit 1
}

x bin/load-canonical-data "$canonical_dir" --geo-output-dir /app/data/geo

echo "==> done."
