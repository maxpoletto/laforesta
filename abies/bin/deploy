#!/usr/bin/env bash
# bin/deploy <dev|prod> [git-ref] [--reset-user]
#
# Drives a deploy on vm-abies via docker context.
#
# dev:           ref optional. With a ref, performs fetch+checkout. Without,
#                deploys the current working tree as-is (uncommitted changes
#                are fair game).
#
# prod:          ref required (tag or sha). Refuses to deploy with a dirty
#                tree.
#
# --reset-user:  before the ensure-admin step, delete any existing
#                superuser(s). Combined with DJANGO_SUPERUSER_* env vars in
#                compose/.env.<instance>, this resets the admin to those
#                creds on the next run -- useful if the password was lost.
#
# The docker context name defaults to vm-abies; override with the
# ABIES_DOCKER_CONTEXT env var. Create the context once with:
#
#   docker context create vm-abies --docker host=ssh://maxp@abies.laforesta.it

set -euo pipefail

usage() {
  echo "usage: $(basename "$0") <dev|prod> [git-ref] [--reset-user]" >&2
  exit 1
}

instance=""
ref=""
reset_user=false
for arg in "$@"; do
  case "$arg" in
    --reset-user) reset_user=true ;;
    -h|--help)    usage ;;
    --*)          echo "unknown flag: $arg" >&2; usage ;;
    dev|prod)
      [[ -z "$instance" ]] || usage
      instance="$arg"
      ;;
    *)
      [[ -z "$ref" ]] || usage
      ref="$arg"
      ;;
  esac
done
[[ "$instance" == "dev" || "$instance" == "prod" ]] || usage

cd "$(git rev-parse --show-toplevel)/abies"

case "$instance" in
  dev)
    if [[ -n "$ref" ]]; then
      git fetch --tags origin
      git checkout "$ref"
    fi
    ;;
  prod)
    [[ -n "$ref" ]] || { echo "error: prod deploy requires explicit git ref (tag or sha)" >&2; exit 1; }
    [[ -z "$(git status --porcelain)" ]] || {
      echo "error: working tree has uncommitted changes; refusing prod deploy" >&2
      exit 1
    }
    git fetch --tags origin
    git checkout "$ref"
    ;;
esac

context="${ABIES_DOCKER_CONTEXT:-vm-abies}"
image="abies:${instance}"
compose_file="compose/${instance}.yml"
project="abies-${instance}"

dc() { docker-compose --context "$context" -f "$compose_file" -p "$project" "$@"; }

ts="$(date -u +%Y%m%dT%H%M%SZ)"

# Skip backup on first deploy: nothing to back up yet, and `compose run`
# would fail trying to pull the not-yet-built image.
if docker --context "$context" image inspect "$image" >/dev/null 2>&1; then
  echo "==> backup db.sqlite3 -> backup/db.sqlite3.${ts}"
  dc run --rm abies python -c "
import sqlite3
src = sqlite3.connect('data/db.sqlite3')
dst = sqlite3.connect('backup/db.sqlite3.${ts}')
src.backup(dst)
"
else
  echo "==> first deploy -- skipping backup"
fi

echo "==> build ${image}"
dc build

if [[ "$instance" == "prod" ]]; then
  echo "==> check --deploy"
  dc run --rm abies python manage.py check --deploy --fail-level WARNING
fi

echo "==> stop"
dc down --remove-orphans

echo "==> migrate"
dc run --rm abies python manage.py migrate --noinput

if [[ "$reset_user" == "true" ]]; then
  echo "==> reset superuser(s)"
  dc run --rm abies python manage.py shell --no-imports -c "
from apps.base.models import User
qs = User.objects.filter(is_superuser=True)
n = qs.count()
qs.delete()
print(f'deleted {n} superuser(s)')
"
fi

echo "==> ensure admin"
dc run --rm abies python manage.py shell --no-imports -c "
from apps.base.models import User
import os
if User.objects.filter(is_superuser=True).exists():
    print('superuser exists; skipping')
elif not (os.environ.get('DJANGO_SUPERUSER_USERNAME') and os.environ.get('DJANGO_SUPERUSER_PASSWORD')):
    print('superuser missing and DJANGO_SUPERUSER_USERNAME/PASSWORD unset; skipping')
    print('(set them in compose/.env.<instance> to auto-create on next deploy)')
else:
    u = User.objects.create_superuser(
        username=os.environ['DJANGO_SUPERUSER_USERNAME'],
        email=os.environ.get('DJANGO_SUPERUSER_EMAIL', ''),
        password=os.environ['DJANGO_SUPERUSER_PASSWORD'],
    )
    u.role = 'admin'
    u.save(update_fields=['role'])
    print(f'superuser {u.username!r} created')
"

echo "==> collectstatic"
dc run --rm abies python manage.py collectstatic --noinput

if [[ "$instance" == "prod" ]]; then
  echo "==> minify static JS"
  dc run --rm abies bin/minify-static /app/staticfiles
fi

echo "==> start"
dc up -d

echo
dc ps
