#!/usr/bin/env bash
# bin/deploy <dev|prod> [git-ref] [--reset-user]
#
# Drives a deploy on vm-abies via docker context.
#
# dev:           ref optional. With a ref, builds a temporary archived copy of
#                that ref. Without, deploys the current working tree as-is
#                (uncommitted changes are fair game).
#
# prod:          ref required (tag or sha). Builds a temporary archived copy of
#                that ref. Refuses to deploy with a dirty tree.
#
# --reset-user:  before the ensure-admin step, delete any existing
#                superuser(s). Combined with DJANGO_SUPERUSER_* env vars in
#                compose/.env.<instance>, this resets the admin to those
#                creds on the next run -- useful if the password was lost.
#
# The docker context name defaults to vm-abies; override with the
# ABIES_DOCKER_CONTEXT env var. Create the context once with:
#
#   docker context create vm-abies --docker host=ssh://maxp@abies.laforesta.it

set -euo pipefail

usage() {
  echo "usage: $(basename "$0") <dev|prod> [git-ref] [--reset-user]" >&2
  exit 1
}

instance=""
ref=""
reset_user=false
for arg in "$@"; do
  case "$arg" in
    --reset-user) reset_user=true ;;
    -h|--help)    usage ;;
    --*)          echo "unknown flag: $arg" >&2; usage ;;
    dev|prod)
      [[ -z "$instance" ]] || usage
      instance="$arg"
      ;;
    *)
      [[ -z "$ref" ]] || usage
      ref="$arg"
      ;;
  esac
done
[[ "$instance" == "dev" || "$instance" == "prod" ]] || usage

repo_root="$(git rev-parse --show-toplevel)"
source_app_dir="$repo_root/abies"
deploy_root=""
deploy_version=""

cleanup() {
  if [[ -n "$deploy_root" && -d "$deploy_root" ]]; then
    rm -rf "$deploy_root"
  fi
}
trap cleanup EXIT

case "$instance" in
  dev)
    ;;
  prod)
    [[ -n "$ref" ]] || { echo "error: prod deploy requires explicit git ref (tag or sha)" >&2; exit 1; }
    [[ -z "$(git -C "$repo_root" status --porcelain)" ]] || {
      echo "error: working tree has uncommitted changes; refusing prod deploy" >&2
      exit 1
    }
    ;;
esac

app_dir="$source_app_dir"
if [[ -n "$ref" ]]; then
  git -C "$repo_root" fetch --tags origin
  deploy_version="$(git -C "$repo_root" describe --tags --always "$ref")"
  deploy_root="$(mktemp -d "${TMPDIR:-/tmp}/abies-deploy.XXXXXX")"
  git -C "$repo_root" archive "$ref" | tar -x -C "$deploy_root"
  app_dir="$deploy_root/abies"

  env_src="$source_app_dir/compose/.env.${instance}"
  env_dst="$app_dir/compose/.env.${instance}"
  [[ -f "$env_src" ]] || {
    echo "error: $env_src missing; required for ${instance} deploy" >&2
    exit 1
  }
  cp "$env_src" "$env_dst"
else
  deploy_version="$(git -C "$repo_root" describe --tags --always --dirty)"
  if [[ -n "$(git -C "$repo_root" status --porcelain)" && "$deploy_version" != *-dirty ]]; then
    deploy_version="${deploy_version}-dirty"
  fi
fi

cd "$app_dir"
export ABIES_VERSION="$deploy_version"

context="${ABIES_DOCKER_CONTEXT:-vm-abies}"
image="abies:${instance}"
compose_file="compose/${instance}.yml"
project="abies-${instance}"

dc() { docker-compose --context "$context" -f "$compose_file" -p "$project" "$@"; }
dc_run() { dc run -T --rm "$@"; }

echo "==> sync branding"
ABIES_BRANDING_DIR="$source_app_dir/data/branding" bin/sync-branding

echo "==> build ${image}"
echo "==> version ${ABIES_VERSION}"
dc build

echo "==> pre-deploy backup"
dc_run abies bin/backup --instance "$instance" --reason predeploy --allow-missing

if [[ "$instance" == "prod" ]]; then
  echo "==> check --deploy"
  dc_run abies python manage.py check --deploy --fail-level WARNING
fi

echo "==> stop"
dc down --remove-orphans

echo "==> migrate"
dc_run abies python manage.py migrate --noinput

if [[ "$reset_user" == "true" ]]; then
  echo "==> reset superuser(s)"
  dc_run abies python manage.py shell --no-imports -c "
from apps.base.models import User
qs = User.objects.filter(is_superuser=True)
n = qs.count()
qs.delete()
print(f'deleted {n} superuser(s)')
"
fi

echo "==> ensure admin"
dc_run abies python manage.py shell --no-imports -c "
from apps.base.models import User
import os
if User.objects.filter(is_superuser=True).exists():
    print('superuser exists; skipping')
elif not (os.environ.get('DJANGO_SUPERUSER_USERNAME') and os.environ.get('DJANGO_SUPERUSER_PASSWORD')):
    print('superuser missing and DJANGO_SUPERUSER_USERNAME/PASSWORD unset; skipping')
    print('(set them in compose/.env.<instance> to auto-create on next deploy)')
else:
    u = User.objects.create_superuser(
        username=os.environ['DJANGO_SUPERUSER_USERNAME'],
        email=os.environ.get('DJANGO_SUPERUSER_EMAIL', ''),
        password=os.environ['DJANGO_SUPERUSER_PASSWORD'],
    )
    u.role = 'admin'
    u.save(update_fields=['role'])
    print(f'superuser {u.username!r} created')
"

echo "==> collectstatic"
dc_run abies python manage.py collectstatic --noinput

if [[ "$instance" == "prod" ]]; then
  echo "==> minify static JS"
  dc_run abies bin/minify-static /app/staticfiles
fi

echo "==> normalize static permissions"
dc_run abies sh -c "find /app/staticfiles -type d -exec chmod 755 {} + && find /app/staticfiles -type f -exec chmod 644 {} +"

echo "==> start"
dc up -d

echo
dc ps
