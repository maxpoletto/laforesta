# Copy to .env.prod and fill in the values. Real .env.prod is gitignored.
# Compose loads this file when bin/deploy invokes it; values land in the
# container's environment but never on the VM filesystem.

# --- Django ----------------------------------------------------------------
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=abies.laforesta.it
DJANGO_CSRF_TRUSTED_ORIGINS=https://abies.laforesta.it
DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# --- MS 365 OAuth (Entra) --------------------------------------------------
MS_OAUTH_CLIENT_ID=
MS_OAUTH_SECRET=
MS_OAUTH_TENANT=

# --- Initial admin (auto-created by bin/deploy on first run) ---------------
# Read by bin/deploy's "ensure admin" step. All optional: if any are unset,
# bin/deploy skips admin creation and you can do it manually with a one-shot
# `manage.py createsuperuser`. For prod, leaving these unset and creating
# the admin interactively once is the safer choice (no secret on disk).
# `bin/deploy prod --reset-user <ref>` deletes existing superusers first.
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
