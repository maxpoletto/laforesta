# Copy to .env.local for local development. Real .env.local is gitignored.
# The Makefile shell-sources this file for local targets only.

# --- Django ----------------------------------------------------------------
DJANGO_SECRET_KEY=django-insecure-local-dev
DJANGO_DEBUG=1

# --- Branding --------------------------------------------------------------
ABIES_APP_NAME=Abies
ABIES_BRAND_NAME=Local
ABIES_SITE_TITLE='Abies local'

# --- Ipso -----------------------------------------------------------------
# Optional unless testing Ipso uploads locally.
ABIES_IPSO_SECRET=

# --- MS 365 OAuth (Entra) --------------------------------------------------
# Optional unless testing Microsoft login locally.
MS_OAUTH_CLIENT_ID=
MS_OAUTH_SECRET=
MS_OAUTH_TENANT=

# --- Initial admin ---------------------------------------------------------
# Optional: if unset, `make dev` prompts when creating the first admin.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
