# Copy to .env.dev and fill in the values. Real .env.dev is gitignored.
# Compose loads this file when bin/deploy invokes it; values land in the
# container's environment but never on the VM filesystem.

# --- Django ----------------------------------------------------------------
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=abies-dev.laforesta.it
DJANGO_CSRF_TRUSTED_ORIGINS=https://abies-dev.laforesta.it
DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# --- Branding --------------------------------------------------------------
ABIES_APP_NAME=Abies
ABIES_BRAND_NAME=<deployment-brand-name>
ABIES_SITE_TITLE=Abies dev

# --- Ipso -----------------------------------------------------------------
ABIES_IPSO_SECRET=

# --- MS 365 OAuth (Entra) --------------------------------------------------
MS_OAUTH_CLIENT_ID=
MS_OAUTH_SECRET=
MS_OAUTH_TENANT=

# --- Initial admin (auto-created by bin/deploy on first run) ---------------
# Read by `manage.py createsuperuser --noinput`-style logic in bin/deploy.
# All optional: if any are unset, bin/deploy skips admin creation and you
# can do it manually with a one-shot `manage.py createsuperuser`.
# `bin/deploy dev --reset-user` deletes existing superusers first; combined
# with these vars set, that resets the admin to fresh creds.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
