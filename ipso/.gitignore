# Build artifacts vendored from elsewhere in the repo at build time.
# `geo.js` is generated by tools/vendor_geo.py from
# abies/apps/base/static/base/js/geo.js; `terreni.geojson` is copied
# from bosco/data/terreni.geojson. Run `make geo terreni` to produce
# them (also part of `make deploy`).
geo.js
terreni.geojson
