#!/usr/bin/env bash
# local-test: bring up ipso-upload + the local reverse proxy in one shot.
#
# Topology mimics production: a single origin (http://127.0.0.1:8000/)
# serves the PWA from build/ and proxies /upload to the upload-server on
# 127.0.0.1:8765. No CORS preflight involved.
#
# Usage: from ipso/, run `make local-test` (or this script directly).

set -euo pipefail

cd "$(dirname "$0")/.."

CONFIG="upload-server/config.local.json"

if [ ! -f "$CONFIG" ]; then
  echo "ERROR: $CONFIG missing."
  echo
  echo "Create it from the committed example:"
  echo "  cp upload-server/config.example.json $CONFIG"
  echo "  # then edit upload_dir to a local path, e.g. /tmp/ipso-upload-dev"
  echo "  # and allowed_origins to include http://127.0.0.1:8000"
  exit 1
fi

# Read upload_dir from the local config and ensure it exists.
UPLOAD_DIR=$(python3 -c "import json,sys; print(json.load(open('$CONFIG'))['upload_dir'])")
mkdir -p "$UPLOAD_DIR"

echo "local-test:"
echo "  upload-server cfg : $CONFIG"
echo "  upload_dir        : $UPLOAD_DIR"
echo

# Start the upload-server in the background; kill it on exit.
(cd upload-server && exec python3 server.py config.local.json) &
UPSERVER_PID=$!
trap 'kill "$UPSERVER_PID" 2>/dev/null || true; wait "$UPSERVER_PID" 2>/dev/null || true' EXIT INT TERM

# Wait for the upload-server to accept connections (max ~2 s).
for _ in $(seq 1 100); do
  if curl -fsS -o /dev/null -X OPTIONS http://127.0.0.1:8765/upload 2>/dev/null; then
    break
  fi
  sleep 0.02
done

# Run the reverse proxy in the foreground.
exec python3 tools/local-proxy.py 8000 build
